# VIKSORASPORTS Client Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI Configuration (Optional - chatbot will use fallback responses without this)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# API Configuration
VITE_API_URL=https://api.viksorasports.com
# For local development use: VITE_API_URL=http://localhost:5000

# Google OAuth Configuration
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# Production Domain Configuration
VITE_PRODUCTION_URL=https://www.viksorasports.com
VITE_API_PRODUCTION_URL=https://api.viksorasports.com